{
  "name": "@slaw-ai/plugin-authoring-smoke-example",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "A Slaw plugin",
  "scripts": {
    "prebuild": "pnpm --filter @slaw-ai/plugin-sdk ensure-build-deps",
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "slaw-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @slaw-ai/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "slawPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "slaw",
    "plugin",
    "connector"
  ],
  "author": "Plugin Author",
  "license": "MIT",
  "dependencies": {
    "@slaw-ai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.16",
    "esbuild": "^0.27.7",
    "rollup": "^4.61.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
