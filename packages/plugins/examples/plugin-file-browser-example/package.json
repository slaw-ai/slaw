{
  "name": "@slaw-ai/plugin-file-browser-example",
  "version": "0.1.0",
  "description": "Example plugin: project sidebar Files link + project detail tab with workspace selector and file browser",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "slawPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "pnpm --filter @slaw-ai/plugin-sdk ensure-build-deps",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @slaw-ai/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@slaw-ai/plugin-sdk": "workspace:*",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
