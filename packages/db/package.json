{
  "name": "@slaw-ai/db",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/slaw-ai/slaw",
  "bugs": {
    "url": "https://github.com/slaw-ai/slaw/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/slaw-ai/slaw",
    "directory": "packages/db"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check:migrations": "tsx src/check-migration-numbering.ts",
    "build": "pnpm run check:migrations && tsc && rm -rf dist/migrations && cp -r src/migrations dist/migrations",
    "clean": "rm -rf dist",
    "typecheck": "pnpm run check:migrations && tsc --noEmit",
    "generate": "pnpm run check:migrations && tsc -p tsconfig.json && drizzle-kit generate",
    "migrate": "pnpm run check:migrations && tsx src/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@slaw-ai/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "embedded-postgres": "18.1.0-beta.16",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
